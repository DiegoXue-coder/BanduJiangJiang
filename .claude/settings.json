{
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "PowerShell(*)",
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull --ff-only origin main 2>&1 | head -n 5 || true",
            "timeout": 30,
            "statusMessage": "Syncing shared repo (git pull)..."
          }
        ]
      }
    ]
  }
}
